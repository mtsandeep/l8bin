# Domain
DOMAIN=localhost

# Dashboard subdomain (served at {DASHBOARD_SUBDOMAIN}.{DOMAIN})
DASHBOARD_SUBDOMAIN=l8bin

# Wake-report subdomain (agent → orchestrator HMAC endpoint)
POKE_SUBDOMAIN=poke

# Caddy
CADDY_ADMIN_URL=http://caddy:2019

# Database
DATABASE_URL=sqlite:./data/litebin.db

# Docker
DOCKER_NETWORK=litebin-network
# Server
HOST=0.0.0.0
PORT=5080

# Sleep / Janitor
DEFAULT_AUTO_STOP_MINS=15
JANITOR_INTERVAL_SECS=300
FLUSH_INTERVAL_SECS=60

# Multi-node mTLS — Orchestrator (master) side
# CA cert to verify agent certificates; client cert/key for master's mTLS identity
# Leave empty for single-node / local-only mode
MASTER_CA_CERT_PATH=
MASTER_CLIENT_CERT_PATH=
MASTER_CLIENT_KEY_PATH=

# Heartbeat interval for worker node health checks (seconds)
HEARTBEAT_INTERVAL_SECS=30

# Public IP — auto-detected on startup via external services
# Only set manually if auto-detection is wrong (e.g. behind NAT)
PUBLIC_IP=

# Routing mode — also configurable via Dashboard → Settings → General (no restart needed)
ROUTING_MODE=master_proxy        # "master_proxy" (default) or "cloudflare_dns"

# Cloudflare DNS — only needed if ROUTING_MODE=cloudflare_dns
# Also configurable via Dashboard → Settings → General
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ── Agent (worker node) ────────────────────────────────────────
# All agent-only variables use AGENT_ prefix.
# These are NOT needed on the master/orchestrator node.

# AGENT_PORT=8443              # default, change only if 8443 is taken on the worker
AGENT_CERT_PATH=               # agent's server cert for mTLS
AGENT_KEY_PATH=                # agent's server key for mTLS
AGENT_CA_CERT_PATH=            # CA cert to verify orchestrator

# Optional overrides
# AGENT_PUBLIC_IP=             # auto-detected on startup; set manually if behind NAT
# AGENT_CADDY_ADMIN_URL=http://localhost:2019  # local Caddy sidecar admin API
